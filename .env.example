# ─── Required at boot ──────────────────────────────────────────────────────────
# PostgreSQL connection string. The Replit DB integration sets this automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/concierge_dev

# Long random string used to sign Express sessions.
SESSION_SECRET=replace-with-a-long-random-string

# ─── AI features (required for agent turns) ────────────────────────────────────
# Provided by the Replit AI Integrations proxy (OpenAI-compatible endpoint).
AI_INTEGRATIONS_OPENAI_BASE_URL=https://ai-integrations.replit.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-replit-ai-key

# ─── Messaging / Sendblue (required for real iMessage sends) ───────────────────
# Leave unset to run in emulator/dev mode (all sends are no-ops).
SENDBLUE_API_KEY_ID=your-sendblue-key-id
SENDBLUE_API_SECRET_KEY=your-sendblue-secret-key
SENDBLUE_FROM_NUMBER=+1XXXXXXXXXX
# Shared secret for verifying inbound Sendblue webhook payloads.
SENDBLUE_WEBHOOK_SECRET=your-webhook-secret

# ─── Optional ──────────────────────────────────────────────────────────────────
# IANA timezone for all proactive-send scheduling (defaults to America/New_York).
CONCIERGE_TIMEZONE=America/New_York

# Google Places API key for venue and lodging search.
# Without this, search_venues and search_lodging return empty results.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Publicly reachable base URL for the API server (used in deep links, etc.).
PUBLIC_API_URL=https://your-replit-deployment.repl.co

# The Sendblue number users message to reach the concierge.
CONCIERGE_PHONE_NUMBER=+1XXXXXXXXXX

# Quiet-hours window for proactive messages (local time in CONCIERGE_TIMEZONE).
# Proactive sends outside this window are deferred to QUIET_HOURS_END:05.
QUIET_HOURS_START=21
QUIET_HOURS_END=9

# NODE_ENV is set automatically by the start script; override only if needed.
# NODE_ENV=development
